{
  "name": "azul-payments",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Microservicio de pasarela de pagos AZUL (Página de Pago) para membresías de ASI Rep. Dominicana.",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "src/server.ts",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@supabase/supabase-js": "^2.99.1",
    "fastify": "^5.1.0",
    "node-cron": "^3.0.3",
    "tsx": "^4.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
