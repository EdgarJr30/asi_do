# ── Servicio ──────────────────────────────────────────────────────────────────
PORT=8080
# URL pública de ESTE servicio (base de Approved/Declined/CancelUrl que recibe AZUL).
# LOCAL: http://localhost:8080  ·  PROD: la URL pública del servicio desplegado.
SERVICE_PUBLIC_URL=http://localhost:8080
# Origins de la SPA permitidos (CORS + retorno tras el pago). Separar varios con coma.
# Incluye el origin local para que en local el retorno vuelva a local.
ALLOWED_ORIGIN=http://localhost:5173,https://asi-do.netlify.app
# Destino de retorno por defecto si el origin no se reconoce.
# LOCAL: http://localhost:5173  ·  PROD: https://asi-do.netlify.app
APP_URL=http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://jgmojkzthfogynqixkob.supabase.co
SUPABASE_ANON_KEY=
# service_role: solo server-side, jamás en el browser
SUPABASE_SERVICE_ROLE_KEY=

# ── AZUL (Página de Pago) ─────────────────────────────────────────────────────
AZUL_MERCHANT_ID=39038540035
# Para el MerchantID de pruebas 39038540035, AZUL usa este nombre exacto.
# En producción, reemplazar por el MerchantName entregado por AZUL para la afiliación real.
AZUL_MERCHANT_NAME=Prueba AZUL
AZUL_MERCHANT_TYPE=ECommerce
# Llave secreta para el HMAC SHA-512 (entregada por AZUL en la afiliación)
AZUL_AUTH_KEY=
AZUL_PAYMENT_URL=https://pruebas.azul.com.do/PaymentPage/
AZUL_PAYMENT_ALT_URL=https://contpagos.azul.com.do/PaymentPage/Default.aspx
AZUL_ENVIRONMENT=test
AZUL_CURRENCY_CODE=$
# 1 = AZUL muestra su pantalla de resultado ("Finish/Download") antes de retornar a la app.
# 0 = AZUL retorna directo a ApprovedUrl/DeclinedUrl/CancelUrl.
AZUL_SHOW_TRANSACTION_RESULT=1

# ── Conciliación (Webservice de consulta de AZUL — credenciales por confirmar) ──
AZUL_VERIFY_API_URL=
AZUL_VERIFY_API_KEY=
RECONCILE_CRON=*/5 * * * *
RECONCILE_STALE_MINUTES=15
RECONCILE_ENABLED=true
