# Copia este archivo a `.env.local` y rellena los valores reales (no se versiona).
# Las URLs por entorno (VITE_AUTH_SITE_URL / APP_URL) viven en .env.development y .env.production.

# --- App / Supabase (cliente, expuestas al browser con prefijo VITE_) ---
VITE_APP_NAME=asi_do
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WEB_PUSH_PUBLIC_KEY=

# URL pública del microservicio de pagos AZUL (services/azul-payments, desplegado en Railway/Render)
VITE_AZUL_PAYMENTS_URL=

# --- Correo (Resend) ---
EMAIL_FROM_ADDRESS=
RESEND_API_KEY=
EMAIL_PROCESSOR_SECRET=

# --- Servidor / scripts (NUNCA prefijar con VITE_; no exponer al browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Tests E2E (Playwright) ---
E2E_BASE_URL=http://127.0.0.1:4173
